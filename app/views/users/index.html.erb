<head>
  <title>Racers</title>
  <%= render "shared/navbar" %>
</head>
<div class="container-fluid">
  <table class="table table-hover table-bordered">
    <thead>
    <tr>
      <th>First Name</th>
      <th>Last Name</th>
      <th>Admin Permissions </th>
      <th>Racer ID</th>
      <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= user.first_name %></td>
        <td><%= user.last_name %></td>
        <td>
          <% if user.admin? %>
            <span class="label label-success">Admin</span>
          <% else %>
            <span class="label label-default">No</span>
          <% end %>
        </td>
        <td><%= user.racer_id %></td>
        <td>
          <%= link_to "View", user_path(user), class: "btn btn-default btn-xs" %>
          <% if current_user && current_user.admin? && current_user != user %>
            <%= link_to(
              user.admin? ? "Remove Admin" : "Make Admin",
              toggle_admin_user_path(user),
              method: :post,
              class: "btn btn-xs #{user.admin? ? 'btn-warning' : 'btn-success'}"
            ) %>
          <% end %>
          <%= link_to 'Destroy', user_path(user), method: :delete, class: "btn btn-danger btn-xs" if current_user && current_user.admin? %>
        </td>
      </tr>
    <% end %>
    </tbody>
  </table>
</div>