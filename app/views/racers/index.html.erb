<head>
  <title>Racers</title>
  <%= render "shared/navbar_racers" %>
</head>

<% begin %>
<div class="container-fluid">
  <h1>Racers Debug</h1>
  <p>Total: <%= @racers.respond_to?(:total_entries) ? @racers.total_entries : @racers.count %></p>
  <table class="table table-hover table-bordered sortable">
    <thead>
      <tr>
        <th>Racer</th>
        <th>Longest Streak</th>
        <th>Current Streak</th>
        <th>Results</th>
      </tr>
    </thead>
    <tbody>
      <% @racers.each do |racer| %>
        <tr>
          <td><%= link_to racer.first_name + " " + racer.last_name, racer_path(racer) %></td>
          <td><%= racer.longest_streak %></td>
          <td><%= racer.current_streak %></td>
          <td><%= racer.race_count %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <div class="apple_pagination">
    <%= will_paginate @racers %>
  </div>
</div>
<% rescue => e %>
  <% logger.error "Template error: #{e.class}: #{e.message}" %>
  <% puts "Template error: #{e.class}: #{e.message}" %>
  <% if e.backtrace %>
    <% logger.error "Backtrace: #{e.backtrace.join("\n")}" %>
    <% puts "Backtrace: #{e.backtrace.join("\n")}" %>
  <% end %>
  <div class="container-fluid">
    <h1>Error rendering page</h1>
    <p><%= e.class %>: <%= e.message %></p>
  </div>
<% end %>