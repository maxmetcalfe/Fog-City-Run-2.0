<head>
  <title>Racers</title>
  <%= render "shared/navbar_racers" %>
</head>
<div class="container-fluid">
  <table class="table table-hover table-bordered sortable">
    <thead>
      <tr>
        <th>Racer</th>
        <th>Longest Streak</th>
        <th>Current Streak</th>
        <th>Results</th>
      </tr>
    </thead>
    <tbody>
      <% @racers.order("race_count DESC").each do |racer| %>
        <tr>
          <td>
            <%= link_to racer.first_name + " " + racer.last_name, racer_path(racer) %>
            <% if current_user && (user = User.find_by(racer_id: racer.id)) && user.strava_link.present? %>
              <%= link_to image_tag("icon-strava-blue.svg", height: 18), user.strava_link, :class => "fa-fw fa-lg" %>
            <% end %>
          </td>
          <td><%= racer.longest_streak %></td>
          <td><%= racer.current_streak %></td>
          <td><%= racer.race_count %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <div class="apple_pagination">
    <%= will_paginate @racers %>
  </div>
</div>